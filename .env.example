# Which settings module to load: "dev" or "prod"
DJANGO_ENV=dev

# Django secret keys — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_DEV_KEY=your-dev-secret-key
DJANGO_SECURE_PRODUCTION_KEY=your-prod-secret-key

# Database (dev)
DEV_DATABASE_NAME=kinorg_dev
DEV_DATABASE_USER=kinorguser
DEV_DATABASE_PASSWORD=your-dev-db-password

# Database (prod)
DATABASE_NAME=kinorgdb
DATABASE_USER=kinorguser
DATABASE_PASSWORD=your-prod-db-password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# TMDB API — get a key at https://www.themoviedb.org/settings/api
TMDB_KEY=your-tmdb-api-key

# Admin email (used for scrape failure alerts etc.)
ADMIN_EMAIL=you@example.com

# Amazon Associates affiliate tag (optional)
AMAZON_ASSOCIATE_TAG=your-tag-20

# Mailgun (prod only)
MAILGUN_API_KEY=your-mailgun-key

# Bugsnag error tracking (prod only)
BUGSNAG_API_KEY=your-bugsnag-key
PATH_TO_YOUR_APP=/path/to/kinorg2
